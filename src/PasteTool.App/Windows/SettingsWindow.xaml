<Window x:Class="PasteTool.App.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasteTool 设置"
        Width="460"
        Height="370"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei UI"
        Background="#FFF7F2EA">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="设置"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#1F1A17" />
            <TextBlock Text="快捷键、自启动和缓存上限都在这里。"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="#6E6259" />
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="全局快捷键"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Foreground="#1F1A17" />
            <TextBox x:Name="HotkeyTextBox"
                     Height="40"
                     Padding="12,8"
                     IsReadOnly="True"
                     Background="#FFFFFBF6"
                     BorderBrush="#D8C8B2"
                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" />
            <TextBlock Text="点击输入框后直接按组合键，至少带一个修饰键。"
                       Margin="0,6,0,0"
                       FontSize="12"
                       Foreground="#6E6259" />
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="历史条数上限"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Foreground="#1F1A17" />
            <TextBox x:Name="MaxEntriesTextBox"
                     Height="40"
                     Padding="12,8"
                     Background="#FFFFFBF6"
                     BorderBrush="#D8C8B2" />
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="图片缓存上限（MB）"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Foreground="#1F1A17" />
            <TextBox x:Name="MaxImageCacheTextBox"
                     Height="40"
                     Padding="12,8"
                     Background="#FFFFFBF6"
                     BorderBrush="#D8C8B2" />
        </StackPanel>

        <CheckBox x:Name="StartWithWindowsCheckBox"
                  Grid.Row="7"
                  Margin="0,16,0,0"
                  VerticalAlignment="Top"
                  Content="开机自动启动 PasteTool"
                  Foreground="#1F1A17" />

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="80"
                    Height="36"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"
                    Background="#E9D9C3"
                    BorderBrush="#C2A37A"
                    Foreground="#2A1F1B"
                    Content="取消" />
            <Button Width="88"
                    Height="36"
                    Click="SaveButton_Click"
                    Background="#C96442"
                    BorderBrush="#C96442"
                    Foreground="White"
                    Content="保存" />
        </StackPanel>
    </Grid>
</Window>
